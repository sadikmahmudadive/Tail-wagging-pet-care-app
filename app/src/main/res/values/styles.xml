<resources>
    <style name="CalendarWeekDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#fffdfc</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="ChipCategory">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/chip_gray</item>
    </style>
    <!-- Custom Dialog Theme -->
    <style name="MyCustomDialogTheme" parent="Theme.AppCompat.Dialog">
        <!-- Background with rounded corners -->
        <item name="android:windowBackground">@drawable/bg_profile_popup</item>
        <!-- Window min width as percentage -->
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <!-- Remove default dialog title divider -->
        <item name="android:windowNoTitle">true</item>
        <!-- Animations -->
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <!-- Accent and text colors -->
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/dark_gray</item>
    </style>

    <!-- Dialog animation style -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="PetDetailLabel" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/grey_dark</item>
        <item name="android:layout_columnWeight">0</item> <!-- Labels don't expand -->
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PetDetailValue" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">0dp</item> <!-- Will take remaining space -->
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/dark_gray</item>
        <item name="android:layout_columnWeight">1</item> <!-- Values expand -->
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:layout_marginStart">8dp</item>
    </style>

    <style name="PetAttributeContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/bg_pet_attribute</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="PetAttributeLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka</item>
        <item name="android:textColor">@color/grey_dark</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="PetAttributeValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/dark_blue</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="StatusButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/status_red_btn</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="HealthTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="HealthSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="HealthCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeWidth">0dp</item>
    </style>

</resources>