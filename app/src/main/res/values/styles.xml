<resources>
    <style name="CalendarWeekDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#fffdfc</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="ChipCategory">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/chip_gray</item>
    </style>

    <!-- Dialog animation style -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="PetDetailLabel" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/grey_dark</item>
        <item name="android:layout_columnWeight">0</item> <!-- Labels don't expand -->
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PetDetailValue" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">0dp</item> <!-- Will take remaining space -->
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/dark_gray</item>
        <item name="android:layout_columnWeight">1</item> <!-- Values expand -->
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:layout_marginStart">8dp</item>
    </style>

    <style name="PetAttributeContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/bg_pet_attribute</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="PetAttributeLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka</item>
        <item name="android:textColor">@color/grey_dark</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="PetAttributeValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/dark_blue</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="StatusButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/status_red_btn</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="HealthTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="HealthSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="HealthCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="CalendarWeekDayModern">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/grey_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
    </style>

    <style name="RoundedCorner8">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="RoundedCorner16">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="RoundedCorner12">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="RoundedCorner24">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TopRoundedCard">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="AppBarGreetingText">
        <item name="android:fontFamily">@font/fredoka</item>
        <item name="android:textColor">@color/app_bar_greeting</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="AppBarUserNameText">
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

</resources>