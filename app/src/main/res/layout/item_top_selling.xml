<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProduct"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/pet1"
            app:shapeAppearanceOverlay="@style/RoundedCorner12" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka"
                android:textColor="@color/health_green"
                android:textSize="11sp"
                tools:text="Royal Canin" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka_bold"
                android:textColor="@color/black"
                android:textSize="14sp"
                tools:text="Rottweiler Puppy" />

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka"
                android:textColor="@color/grey_medium"
                android:textSize="11sp"
                tools:text="3kg" />

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_rounded_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:fontFamily="@font/fredoka"
                android:textColor="@color/orange"
                android:textSize="9sp"
                tools:text="Furry" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAddToCart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_light_blue"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_quantity_add"
            app:tint="@color/white"
            android:contentDescription="Add to cart" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
