<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navigationCard"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_gravity="bottom"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="20dp"
    app:cardCornerRadius="36dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="12dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/dark_blue"
                android:contentDescription="@string/nav_profile"/>
        </LinearLayout>

        <!-- Calendar -->
        <LinearLayout
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/dark_blue"
                android:contentDescription="@string/nav_calendar"/>
        </LinearLayout>

        <!-- Add Pet (Center Floating Action Style) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navAddPet"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/md_theme_light_primary"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add_pet"
                app:tint="@color/white"
                android:contentDescription="@string/nav_add_pet"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Manage -->
        <LinearLayout
            android:id="@+id/navManage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_paw"
                app:tint="@color/dark_blue"
                android:contentDescription="@string/nav_manage"/>
        </LinearLayout>

        <!-- Vet -->
        <LinearLayout
            android:id="@+id/navVet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_vet"
                app:tint="@color/dark_blue"
                android:contentDescription="@string/nav_vet"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>