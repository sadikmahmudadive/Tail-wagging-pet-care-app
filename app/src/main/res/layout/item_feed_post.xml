<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Instagram-style User Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivPostUser"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_profile"
            app:civ_border_color="#DBDBDB"
            app:civ_border_width="1dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@+id/ivPostUser"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPostUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka_bold"
                android:textColor="@color/black"
                android:textSize="14sp"
                tools:text="alex_johnson" />

            <ImageView
                android:id="@+id/ivVerifiedBadge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_verified"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvPostTypeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_post_type"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:fontFamily="@font/fredoka_bold"
                tools:text="ADOPTION" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMoreOptions"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/black" />
    </RelativeLayout>

    <!-- Post Image -->
    <FrameLayout
        android:id="@+id/postImageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivPostImage"
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:scaleType="centerCrop"
            android:src="@drawable/pet1"
            app:shapeAppearanceOverlay="@null" />

        <!-- Double Tap Heart Overlay -->
        <ImageView
            android:id="@+id/ivPostHeartOverlay"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_paw"
            app:tint="@color/white"
            android:alpha="0"
            android:scaleX="0"
            android:scaleY="0" />
    </FrameLayout>

    <!-- Actions Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ivLikeIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_margin="6dp"
            android:src="@drawable/ic_heart_fill"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/btnCommentPost"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_margin="6dp"
            android:src="@drawable/ic_comment"
            android:alpha="0.8"
            app:tint="@color/black" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btnSharePost"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_margin="6dp"
            android:src="@drawable/ic_share"
            android:alpha="0.6"
            app:tint="@color/black" />
    </LinearLayout>

    <!-- Likes Count -->
    <TextView
        android:id="@+id/tvLikesCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:fontFamily="@font/fredoka_bold"
        android:textColor="@color/black"
        android:textSize="14sp"
        tools:text="1,245 likes" />

    <!-- Caption -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            tools:text="alex_johnson Found this cute puppy near the park! #petlover #rescue" />
    </LinearLayout>

    <!-- Time -->
    <TextView
        android:id="@+id/tvPostTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingBottom="16dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/fredoka"
        android:textColor="#8E8E8E"
        android:textSize="10sp"
        tools:text="2 HOURS AGO" />

</LinearLayout>